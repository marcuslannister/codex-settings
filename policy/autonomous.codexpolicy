prefix_rule(
    pattern = ["~/.codex/skills/autonomous-skill/scripts/run-session.sh"],
    decision = "allow",
    match = [
        ["~/.codex/skills/autonomous-skill/scripts/run-session.sh", "--list"],
        ["~/.codex/skills/autonomous-skill/scripts/run-session.sh", "build a small changelog report"],
        ["~/.codex/skills/autonomous-skill/scripts/run-session.sh", "--task-name", "build-changelog", "--continue"],
    ],
)

prefix_rule(
    pattern = ["codex", "exec"],
    decision = "allow",
    match = [
        ["codex", "exec", "-c", "approval_policy=\"never\"", "-c", "sandbox_mode=\"workspace-write\"", "--skip-git-repo-check", "--json", "prompt"],
        ["codex", "exec", "resume", "-c", "approval_policy=\"never\"", "-c", "sandbox_mode=\"workspace-write\"", "--skip-git-repo-check", "--json", "00000000-0000-0000-0000-000000000000", "prompt"],
    ],
)
